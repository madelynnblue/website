---
layout: layouts/base.njk
templateClass: tmpl-home
---

<div class="wrapper home">
  <div class="content">
    {{ content | safe }}
    <h2>Recent posts</h2>
    <ul class="plain-list">
      {%- for post in collections.posts | reverse | limit(5) -%}
      <li>
        {{ post.date | htmlDateString }}
        <a href="{{ post.url }}">{{ post.data.title }}</a>
      </li>
      {%- endfor -%}
    </ul>
    {%- for section_name, subsection in
    collections.sections -%}
    <div>
      <h2>{{ section_name }}</h2>
      {%- for subsection_name, articles in subsection -%}
      <div>
        <h4>{{ subsection_name }}</h4>
        <ul>
          {%- for item in articles -%}
          <li><a href="{{ item.url }}">{{ item.data.article }}</a></li>
          {%- endfor -%}
        </ul>
      </div>
      {%- endfor -%}
    </div>
    {%- endfor -%}

  </div>
</div>
